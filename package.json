{
    "name": "zxcvbn-ts",
    "version": "2.0.2",
    "description": "TypeScript rewrite of zxcvbn — strict types, phone detection, AI feedback, cost-to-crack estimates, and 20+ bug fixes over the original",
    "author": "Kunal Tanwar",
    "license": "MIT",
    "main": "./dist/cjs/index.js",
    "module": "./dist/esm/index.js",
    "types": "./dist/types/index.d.ts",
    "exports": {
        ".": {
            "import": "./dist/esm/index.js",
            "require": "./dist/cjs/index.js",
            "types": "./dist/types/index.d.ts"
        },
        "./ai": {
            "import": "./dist/esm/ai.js",
            "require": "./dist/cjs/ai.js",
            "types": "./dist/types/ai.d.ts"
        }
    },
    "files": [
        "dist/"
    ],
    "scripts": {
        "build": "bun run build:cjs && bun run build:esm && bun run build:types && mkdir -p dist/data && cp data/frequency_lists.json dist/data/frequency_lists.json",
        "build:cjs": "tsc -p tsconfig.cjs.json",
        "build:esm": "tsc -p tsconfig.esm.json",
        "build:types": "tsc -p tsconfig.types.json",
        "typecheck": "tsc --noEmit",
        "test": "bun test",
        "clean": "rm -rf dist"
    },
    "keywords": [
        "password",
        "strength",
        "zxcvbn",
        "zxcvbn-ts",
        "entropy",
        "security",
        "typescript",
        "password-strength",
        "crack-time",
        "phone",
        "ai",
        "passphrase"
    ],
    "repository": {
        "type": "git",
        "url": "https://github.com/KunalTanwar/zxcvbn-ts"
    },
    "homepage": "https://github.com/KunalTanwar/zxcvbn-ts#readme",
    "bugs": {
        "url": "https://github.com/KunalTanwar/zxcvbn-ts/issues"
    },
    "devDependencies": {
        "bun-types": "^1.3.13",
        "typescript": "^5.5.0"
    }
}
